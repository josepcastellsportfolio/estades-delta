# Estades Delta — env template for Phase 1 local dev.
#
# Copy to .env and adjust. .env is gitignored — never commit secrets here.
# Real production secrets land in the VPS host environment in Phase 3+.

# --- Postgres ---
DB_USER=plone
DB_PASSWORD=plonedev
DB_NAME=plone

# --- Plone Site bootstrap (read by scripts/create_site.py on first start) ---
SITE=Plone
TYPE=plone-site
TITLE=Estades Delta
DESCRIPTION=Marketplace direct-booking multi-tenant para alquiler turistico en el Delta del Ebro
LANGUAGE=ca
DEFAULT_LANGUAGE=ca
EXAMPLE_CONTENT=0
DELETE_EXISTING=1
ADDONS="['estades.delta','plone.app.multilingual']"
PROFILES="['estades.delta:default']"

# --- Multi-tenant routing ---
# JSON map of hostname → Volto URL path (WITHOUT language prefix).
# Volto's multilingual router prepends /<defaultLanguage>/ automatically.
# Example: {"casariumar.cat": "/properties/casa-riumar"}
# See middleware/tenantRouting.ts for the Option-A hotfix comment (existing
# content created outside /properties/ needs the full /ca/<path> prefix).
VOLTO_TENANT_MAP={}

# Set to 1 on first `docker compose up` to create demo Properties in Plone.
# NEVER set to 1 in production. See setuphandlers/demo_content.py.
CREATE_DEMO_CONTENT=0

# --- Beds24 (Phase 2+) ---
BEDS24_API_KEY=
BEDS24_API_URL=https://api.beds24.com/v2

# --- Stripe Connect Express (Phase 2+) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- LLM (Phase 3+) ---
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001
