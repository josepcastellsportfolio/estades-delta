# Estades Delta — env template for Phase 1 local dev.
#
# Copy to .env and adjust. .env is gitignored — never commit secrets here.
# Real production secrets land in the VPS host environment in Phase 3+.

# --- Postgres ---
DB_USER=plone
DB_PASSWORD=plonedev
DB_NAME=plone

# --- Plone Site bootstrap (read by scripts/create_site.py on first start) ---
SITE=Plone
TYPE=plone-site
TITLE=Estades Delta
DESCRIPTION=Marketplace direct-booking multi-tenant para alquiler turistico en el Delta del Ebro
LANGUAGE=ca
DEFAULT_LANGUAGE=ca
EXAMPLE_CONTENT=0
DELETE_EXISTING=1
ADDONS="['estades.delta','plone.app.multilingual']"
PROFILES="['estades.delta:default']"

# --- Multi-tenant routing ---
# The Volto SSR middleware resolves microsite hostnames in this order:
#   1. Dynamic map fetched from Plone at startup + every 10 min
#      (Properties with a `custom_domain` field set)
#   2. Static VOLTO_TENANT_MAP fallback (this var)
#   3. Subdomain wildcard *.estadesdelta.{cat,local} → /properties/<slug>
#
# Use VOLTO_TENANT_MAP for Option-A hotfixes (paths not following the
# /properties/<slug> shape, e.g. legacy content under /ca/Josep-test/...) and
# as a cold-start fallback before the first dynamic fetch resolves. In
# production with Plone reachable, you can usually leave it as {}.
# Example: {"casariumar.cat": "/properties/casa-riumar"}
VOLTO_TENANT_MAP={}

# Set to 1 on first `docker compose up` to create demo Properties in Plone.
# NEVER set to 1 in production. See setuphandlers/demo_content.py.
CREATE_DEMO_CONTENT=0

# --- Beds24 (Phase 2+) ---
BEDS24_API_KEY=
BEDS24_API_URL=https://api.beds24.com/v2

# --- Stripe Connect Express (Phase 2+) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- LLM (Phase 1 — M1 Messaging IA) ---
# M1 uses Llama self-hosted via Ollama (containerised). See ADR-020.
# If LLM_BASE_URL is empty or unreachable, the LLM adapter falls back to
# MockLLMAdapter (deterministic, used by the test suite). Do NOT rely on the
# Mock fallback in production.
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.1:8b-instruct
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
# Embedding dimension MUST match the model used (nomic-embed-text=768,
# OpenAI text-embedding-3=1536). The pgvector column is sized from this var.
EMBEDDING_DIM=768

# --- Messaging adapter (M1) ---
# stub | whatsapp_business_api | beds24_messaging
# Only `stub` is implemented in M1. Real adapters land in M3.
MESSAGING_ADAPTER=stub

# Secret used to verify inbound webhook signatures (HMAC SHA-256).
WEBHOOK_HMAC_SECRET=

# Default timezone for scheduled message dispatch (pre-checkin etc.).
SCHEDULED_MESSAGES_TZ=Europe/Madrid

# --- Celery (M1) ---
# Redis broker is the existing service from this compose file.
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- pgvector / embeddings (M1) ---
# Direct DSN for the embedding store (bypasses RelStorage; talks straight to
# the `embeddings` schema reserved in devops/scripts/postgres-init.sql).
EMBEDDINGS_DB_DSN=postgresql://plone:plonedev@postgres:5432/plone
