<?xml version="1.0" encoding="utf-8"?>
<object name="portal_catalog">
  <!--
    FieldIndex on `zone` so AggregatorFilters can filter by it via @search
    (`?zone=Riumar`). Without an index the catalog brains have the value as
    metadata but @search won't filter on it.
  -->
  <index meta_type="FieldIndex" name="zone">
    <indexed_attr value="zone" />
  </index>

  <!--
    Metadata columns exposed on catalog brains so plone.restapi @search returns
    them in `items` without needing fullobjects=true. Required by:
      - Volto tenantRouting middleware (custom_domain → URL path mapping)
      - AggregatorPropertyList block (short_name display, zone filter, prices)
      - Marketplace card rendering (capacity, bedrooms, bathrooms, palette)
  -->
  <column value="custom_domain" />
  <column value="short_name" />
  <column value="zone" />
  <column value="municipality" />
  <column value="max_guests" />
  <column value="bedrooms" />
  <column value="bathrooms" />
  <column value="base_price_low_season" />
  <column value="base_price_mid_season" />
  <column value="base_price_high_season" />
  <column value="palette" />

  <!-- M1: GuestConversation indexes for @conversations and pipeline queries -->
  <index meta_type="FieldIndex" name="channel">
    <indexed_attr value="channel" />
  </index>
  <index meta_type="FieldIndex" name="conversation_mode">
    <indexed_attr value="conversation_mode" />
  </index>
  <index meta_type="DateIndex" name="last_activity">
    <indexed_attr value="last_activity" />
  </index>

  <!-- M1: GuestMessage indexes for dedup and classification queries -->
  <index meta_type="FieldIndex" name="external_message_id">
    <indexed_attr value="external_message_id" />
  </index>
  <index meta_type="FieldIndex" name="direction">
    <indexed_attr value="direction" />
  </index>
  <index meta_type="FieldIndex" name="classification">
    <indexed_attr value="classification" />
  </index>

  <!-- M1: Metadata columns for conversation list rendering -->
  <column value="channel" />
  <column value="last_activity" />
  <column value="direction" />
  <column value="classification" />
  <column value="external_message_id" />
</object>
