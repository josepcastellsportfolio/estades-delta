<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Dexterity FTI"
        name="Owner"
        i18n:domain="plone"
>
  <property name="title"
            i18n:translate=""
  >Owner</property>
  <property name="description"
            i18n:translate=""
  >Property owner (individual or company).</property>
  <property name="icon_expr">string:${portal_url}/user_icon.png</property>
  <property name="factory">Owner</property>
  <property name="add_view_expr">string:${folder_url}/++add++Owner</property>
  <property name="link_target" />
